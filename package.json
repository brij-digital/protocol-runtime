{
  "name": "@brij-digital/apppack-runtime",
  "version": "0.1.43",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brij-digital/apppack-runtime.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "schemas",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./idlDeclarativeRuntime": {
      "types": "./dist/idlDeclarativeRuntime.d.ts",
      "import": "./dist/idlDeclarativeRuntime.js"
    },
    "./runtimeOperationRuntime": {
      "types": "./dist/runtimeOperationRuntime.d.ts",
      "import": "./dist/runtimeOperationRuntime.js"
    },
    "./idlRegistry": {
      "types": "./dist/idlRegistry.d.ts",
      "import": "./dist/idlRegistry.js"
    },
    "./codamaIdl": {
      "types": "./dist/codamaIdl.d.ts",
      "import": "./dist/codamaIdl.js"
    },
    "./node/view-read-service": {
      "types": "./dist/node/view-read-service.d.ts",
      "import": "./dist/node/view-read-service.js"
    },
    "./schemas/*": "./schemas/*"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "schemas:check": "node scripts/check-shared-schemas.mjs",
    "test": "npm run build && node --test test/**/*.test.mjs",
    "prepare": "npm run build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "@coral-xyz/borsh": "^0.31.1",
    "@noble/hashes": "^1.8.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/web3.js": "^1.98.4",
    "bn.js": "^5.2.2",
    "bs58": "^6.0.0",
    "pg": "^8.16.3",
    "vite-plugin-node-polyfills": "^0.25.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.2.0",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.5",
    "typescript": "~5.9.3"
  }
}
