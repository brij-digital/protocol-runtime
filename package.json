{
  "name": "@brij-digital/apppack-runtime",
  "version": "0.2.7",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brij-digital/protocol-runtime.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "schemas",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./idlDeclarativeRuntime": {
      "types": "./dist/idlDeclarativeRuntime.d.ts",
      "import": "./dist/idlDeclarativeRuntime.js",
      "default": "./dist/idlDeclarativeRuntime.js"
    },
    "./runtimeOperationRuntime": {
      "types": "./dist/runtimeOperationRuntime.d.ts",
      "import": "./dist/runtimeOperationRuntime.js",
      "default": "./dist/runtimeOperationRuntime.js"
    },
    "./idlRegistry": {
      "types": "./dist/idlRegistry.d.ts",
      "import": "./dist/idlRegistry.js",
      "default": "./dist/idlRegistry.js"
    },
    "./codamaIdl": {
      "types": "./dist/codamaIdl.d.ts",
      "import": "./dist/codamaIdl.js",
      "default": "./dist/codamaIdl.js"
    },
    "./metaComputeRegistry": {
      "types": "./dist/metaComputeRegistry.d.ts",
      "import": "./dist/metaComputeRegistry.js",
      "default": "./dist/metaComputeRegistry.js"
    },
    "./schemas/*": "./schemas/*"
  },
  "scripts": {
    "npmrc:check": "node scripts/check-local-npmrc.mjs",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "schemas:check": "node scripts/check-shared-schemas.mjs",
    "test": "npm run npmrc:check && npm run build && node --test test/**/*.test.mjs",
    "test:integration:registry": "npm run npmrc:check && npm run build && node --test test/defined-enum-args.integration.test.mjs",
    "prepare": "npm run build",
    "prepublishOnly": "npm run npmrc:check"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "@coral-xyz/borsh": "^0.31.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "bn.js": "^5.2.2",
    "bs58": "^6.0.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.2.0",
    "@types/node": "^24.10.1",
    "typescript": "~5.9.3"
  }
}
